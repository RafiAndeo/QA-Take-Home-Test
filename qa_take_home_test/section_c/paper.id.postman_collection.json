      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {\r",
              "\r",
              "    pm.test(\"Response status is 200\", function () {\r",
              "        pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Response contains a valid token\", function () {\r",
              "        const response = pm.response.json();\r",
              "\r",
              "        pm.expect(response).to.have.property(\"token\");\r",
              "        pm.expect(response.token).to.be.a(\"string\");\r",
              "        pm.expect(response.token).to.not.be.empty;\r",
              "    });\r",
              "\r",
              "} else {\r",
              "\r",
              "    pm.test(\"Response is an expected error\", function () {\r",
              "        pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 404, 422]);\r",
              "    });\r",
              "\r",
              "}"
            ],
